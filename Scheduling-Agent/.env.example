# Environment Variables for the Scheduling Agent
# Copy this file to .env only if you want to use external integrations.
# The local mock agent flow works without these values.

# --- Zoom Server-to-Server OAuth (optional) ---
ZOOM_ACCOUNT_ID=your_zoom_account_id
ZOOM_CLIENT_ID=your_zoom_client_id
ZOOM_CLIENT_SECRET=your_zoom_client_secret

# --- SMTP Email (optional) ---
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# --- AI Models (optional, for legacy AI slot picking) ---
GEMINI_API_KEY=your_gemini_api_key
