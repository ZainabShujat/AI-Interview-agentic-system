{
  "name": "@hireintel/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the HireIntel agentic hiring platform — resume parsing, JD analysis, match scoring, adaptive interviews, and reports.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch",
    "clean": "rimraf dist"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "hireintel",
    "hiring",
    "interview",
    "resume-parser",
    "sdk",
    "typescript"
  ],
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "rimraf": "^5.0.0"
  }
}
